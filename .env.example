# =============================================================
#  Controle - Fichier d'exemple des variables d'environnement
# =============================================================
#
# INSTRUCTIONS :
# 1. Copier ce fichier vers `.env` à la racine du projet :
#      cp .env.example .env         (Linux/macOS/Git Bash)
#      copy .env.example .env      (Windows CMD/PowerShell)
# 2. Remplacer chaque valeur par la configuration réelle.
# 3. NE JAMAIS COMMITER le fichier `.env` (déjà exclu par .gitignore).
#
# Convention : les variables sont regroupées par module fonctionnel,
# conformément à l'arborescence du PRD (Modules A à F) et de l'ARCHITECTURE.
# =============================================================


# -------------------------------------------------------------
# SERVEUR (Backend Node.js / Express)
# -------------------------------------------------------------

# Port d'écoute de l'API
PORT=3001

# Environnement d'exécution : development | production
NODE_ENV=development

# URL publique du backend (utile pour la documentation / les liens dans le dashboard)
BACKEND_URL=http://localhost:3001

# Adresse IP d'écoute (0.0.0.0 = toutes les interfaces ; 127.0.0.1 = local uniquement)
HOST=127.0.0.1


# -------------------------------------------------------------
# SÉCURITÉ DU DASHBOARD (Module F - PRD)
# -------------------------------------------------------------

# Identifiant du superviseur (accès au dashboard web)
SUPERVISOR_USERNAME=admin

# Mot de passe du superviseur (à hasher via bcrypt côté code)
SUPERVISOR_PASSWORD=changeme

# Clé secrète pour signer les sessions / tokens JWT
SESSION_SECRET=changez-cette-cle-en-production-32-caracteres-minimum

# Durée de validité d'une session (en heures)
SESSION_DURATION_HOURS=8


# -------------------------------------------------------------
# GÉOFENCING & VALIDATION GPS (Module C - PRD)
# -------------------------------------------------------------

# Tolérance de précision GPS maximale (en mètres). Au-delà, la capture est refusée.
# Le PRD exige une précision < 4 mètres.
GPS_MAX_ACCURACY_METERS=4

# Activer le mode strict (rejeter toute coordonnée limite)
GPS_STRICT_MODE=true


# -------------------------------------------------------------
# CONTRÔLE DU TEMPS (Module B - PRD)
# -------------------------------------------------------------

# Heure d'ouverture des saisies (format HH:MM, 24h)
TIME_WINDOW_START=07:00

# Heure de fermeture des saisies
TIME_WINDOW_END=19:00

# Début de la pause méridienne
LUNCH_BREAK_START=12:00

# Fin de la pause méridienne
LUNCH_BREAK_END=12:30

# Délai minimum entre deux soumissions (en minutes)
MIN_SUBMISSION_INTERVAL_MINUTES=45

# Tolérance d'écart avec l'heure NTP (en secondes)
NTP_TIME_TOLERANCE_SECONDS=5

# Serveur NTP utilisé pour la vérification anti-fraude horaire
NTP_SERVER=pool.ntp.org


# -------------------------------------------------------------
# ANTI-FRAUDE (Module D - PRD)
# -------------------------------------------------------------

# Activer la détection de Mock Locations (Fake GPS)
ENABLE_MOCK_LOCATION_DETECTION=true

# Activer la vérification Root / Jailbreak
ENABLE_ROOT_DETECTION=true

# Clé API SafetyNet (Android) - fournie par Google Cloud Console
SAFETYNET_API_KEY=

# Bloquer l'application si le device est rooté / jailbreaké
BLOCK_ON_ROOTED_DEVICE=true


# -------------------------------------------------------------
# STOCKAGE DONNÉES
# -------------------------------------------------------------

# Chemin vers le fichier JSON de stockage des soumissions (MVP)
# Par défaut : backend/submissions.json (relatif à la racine du projet)
SUBMISSIONS_FILE=./backend/submissions.json

# Chemin vers le fichier de géographie (limites des communes)
GEOGRAPHY_FILE=./backend/geography.json


# -------------------------------------------------------------
# BASE DE DONNÉES (Production - ARCHITECTURE §2)
# -------------------------------------------------------------
# Le MVP utilise un fichier JSON. Pour la production, PostgreSQL est prévu.
# Décommenter et configurer lors du passage en production.

# Type de base : json (MVP) | postgres (production)
DATABASE_TYPE=json

# Connexion PostgreSQL (uniquement si DATABASE_TYPE=postgres)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=controle
# DB_USER=controle_user
# DB_PASSWORD=
# DB_SSL=false


# -------------------------------------------------------------
# LOGGING & MONITORING
# -------------------------------------------------------------

# Niveau de log : error | warn | info | debug
LOG_LEVEL=info

# Activer la rotation des logs
LOG_TO_FILE=false

# Chemin du fichier de log
LOG_FILE=./logs/controle.log


# -------------------------------------------------------------
# CORS & API
# -------------------------------------------------------------

# Origines autorisées à appeler l'API (séparées par des virgules)
# Exemple : http://localhost:3001,https://controle.example.mg
CORS_ORIGINS=http://localhost:3001

# Activer le rate-limiting (protection contre les abus)
ENABLE_RATE_LIMIT=true

# Nombre maximum de requêtes par IP par minute
RATE_LIMIT_PER_MINUTE=60


# -------------------------------------------------------------
# EXPORT (Module F - PRD)
# -------------------------------------------------------------

# Format d'export par défaut : csv | xlsx
EXPORT_DEFAULT_FORMAT=csv

# Répertoire où stocker temporairement les exports
EXPORT_TEMP_DIR=./tmp/exports


# -------------------------------------------------------------
# NOTIFICATIONS (futur)
# -------------------------------------------------------------
# Configuration SMTP pour l'envoi d'alertes au superviseur
# (Non utilisé dans le MVP, prévu pour les versions ultérieures)

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# NOTIFY_ON_FRAUD_DETECTION=true
# NOTIFY_ON_QUOTA_EXHAUSTED=true
